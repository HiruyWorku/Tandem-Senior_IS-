# ─────────────────────────────────────────────
# Tandem Senior IS — .gitignore
# ─────────────────────────────────────────────

# ── OS / Editor ──────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

.vscode/
.idea/
*.swp
*.swo
*.orig

# ── Node.js ───────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.node_repl_history
*.tsbuildinfo

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
develop-eggs/
eggs/
.eggs/
*.egg-info/
*.egg
MANIFEST
.installed.cfg

# Virtual environments
.env
.envrc
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Test / coverage
.tox/
.nox/
.coverage
.coverage.*
.cache
htmlcov/
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# Distribution / packaging
wheels/
sdist/
var/
parts/
downloads/
lib/
lib64/
share/python-wheels/

# Type checkers / linters
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
cython_debug/

# Jupyter
.ipynb_checkpoints
profile_default/
ipython_config.py

# Flask / Django artefacts
instance/
.webassets-cache
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Docs
docs/_build/
/site

# ── Large ML/training binaries ────────────────
# These files are generated by the training pipeline; do not commit them.
# Use cloud storage (GCS, S3, HuggingFace Hub, Git LFS) for large models.
*.p
*.pickle
*.pkl
model.json
data.pickle

# ── Secrets ───────────────────────────────────
# Real .env values must never be committed.
# Commit .env.example instead.
.env
*.env
!.env.example

# ── Misc tool files ────────────────────────────
.pdm-python
.pdm-build/
.pixi
__pypackages__/
celerybeat-schedule
celerybeat.pid
*.sage.py
.scrappy
.abstra/
.cursorignore
.cursorindexingignore
.pypirc
marimo/_static/
marimo/_lsp/
__marimo__/
